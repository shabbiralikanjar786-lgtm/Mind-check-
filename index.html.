<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MindCheck AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: sans-serif; background-color: #F3F4F6; -webkit-tap-highlight-color: transparent; }
        .bg-mint { background-color: #A8D5BA; }
        .text-mint { color: #A8D5BA; }
        .breathe-anim { animation: pulse 4s infinite ease-in-out; }
        @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.7; } 50% { transform: scale(1.6); opacity: 0.4; } }
        .fade-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div id="app" class="w-full max-w-sm bg-white rounded-[2.5rem] shadow-2xl p-8 text-center border border-white/20">
        <div id="header">
            <h1 class="text-2xl font-bold text-gray-800">MindCheck AI</h1>
            <p id="subtitle" class="text-[10px] tracking-[0.2em] text-gray-400 uppercase mt-1 mb-8">Personal Wellness</p>
        </div>

        <div id="content" class="min-h-[220px] flex flex-col justify-center items-center fade-in">
            <p class="text-gray-500 mb-8 leading-relaxed">Take 30 seconds to check in with yourself.</p>
            <button onclick="startApp()" class="bg-mint text-white w-full py-4 rounded-2xl font-bold shadow-lg shadow-green-100 active:scale-95 transition-transform">Start Assessment</button>
        </div>

        <div class="mt-10 pt-6 border-t border-gray-50 flex justify-around opacity-50">
            <button onclick="startApp()" class="text-xl">📝</button>
            <button onclick="showBreathe()" class="text-xl">🌬️</button>
            <button onclick="showHistory()" class="text-xl">📊</button>
        </div>
    </div>

    <script>
        let score = 0;
        let currentQ = 0;
        const questions = [
            "Have you felt little interest or pleasure in doing things lately?",
            "Have you felt down, depressed, or hopeless this week?",
            "Have you had trouble falling asleep or staying asleep?",
            "Have you felt tired or had very little energy?"
        ];

        function startApp() {
            score = 0; currentQ = 0;
            renderQuestion();
        }

        function renderQuestion() {
            document.getElementById('content').innerHTML = `
                <div class="fade-in">
                    <p class="text-xs text-gray-400 mb-2">Question ${currentQ + 1} of 4</p>
                    <h2 class="text-lg font-medium text-gray-700 mb-6">${questions[currentQ]}</h2>
                    <div class="grid gap-3">
                        <button onclick="next(0)" class="w-full p-4 border rounded-xl hover:bg-green-50 active:bg-green-50 transition">Not at all</button>
                        <button onclick="next(1)" class="w-full p-4 border rounded-xl hover:bg-green-50 active:bg-green-50 transition">Several days</button>
                        <button onclick="next(2)" class="w-full p-4 border rounded-xl hover:bg-green-50 active:bg-green-50 transition">Most days</button>
                    </div>
                </div>`;
        }

        function next(val) {
            score += val;
            if (currentQ < questions.length - 1) {
                currentQ++;
                renderQuestion();
            } else {
                saveAndShow();
            }
        }

        function saveAndShow() {
            localStorage.setItem('lastScore', score);
            const status = score > 4 ? "Take care of yourself today." : "You're doing well!";
            document.getElementById('content').innerHTML = `
                <div class="fade-in">
                    <div class="text-5xl mb-4">🌿</div>
                    <h2 class="text-4xl font-bold text-mint mb-2">${score}</h2>
                    <p class="text-gray-600 font-medium">${status}</p>
                    <p class="text-[10px] text-gray-400 mt-6 italic">Self-check only. Not a medical diagnosis.</p>
                </div>`;
        }

        function showBreathe() {
            document.getElementById('content').innerHTML = `
                <div class="fade-in flex flex-col items-center">
                    <div class="w-20 h-20 bg-mint rounded-full breathe-anim shadow-lg shadow-green-100"></div>
                    <p class="mt-20 text-gray-400 font-light tracking-widest uppercase text-xs">Breathe in... Breathe out...</p>
                </div>`;
        }

        function showHistory() {
            const last = localStorage.getItem('lastScore') || "None";
            document.getElementById('content').innerHTML = `
                <div class="fade-in w-full">
                    <p class="text-xs text-gray-400 uppercase tracking-widest mb-4">Previous Score</p>
                    <div class="bg-gray-50 py-8 rounded-3xl border border-gray-100">
                        <span class="text-5xl font-bold text-gray-700">${last}</span>
                    </div>
                </div>`;
        }
    </script>
</body>
</html>
